Subject: [PATCH] openrewrite
---
Index: build.gradle
IDEA additional info:
Subsystem: com.intellij.openapi.diff.impl.patch.CharsetEP
<+>UTF-8
===================================================================
diff --git a/build.gradle b/build.gradle
--- a/build.gradle	(revision be4ec1ce70280e4809d67ba0db38f632ee449f2c)
+++ b/build.gradle	(date 1774912186715)
@@ -21,6 +21,7 @@
     id 'io.github.goooler.osgi' version '0.8.6'
     id 'com.github.jk1.dependency-license-report' version '3.1.1'
     id 'org.sonarqube' version '7.0.1.6134'
+    id 'org.openrewrite.rewrite' version '7.7.0'
     id 'org.apache.groovy-core'
     id 'java-test-fixtures'
     id 'org.apache.groovy-jacoco-aggregation'
@@ -30,6 +31,18 @@
     archivesName = 'groovy'
 }
 
+rewrite {
+    activeRecipe 'org.openrewrite.staticanalysis.CommonStaticAnalysis'
+    exclusion '**/*.groovy'
+    exclusion '**/*.gradle'
+    exclusion '**/*.xml'
+    plainTextMask '**/*.gradle'
+}
+
+dependencies {
+    rewrite 'org.openrewrite.recipe:rewrite-migrate-java:3.12.0'
+}
+
 groovyLibrary {
     registerOptionalFeature 'gpars'
     registerOptionalFeature 'grapes'
@@ -171,6 +184,7 @@
     tasks.withType(AbstractCopyTask).configureEach {
         it.duplicatesStrategy = DuplicatesStrategy.WARN
     }
+
 }
 
 tasks.named('jar') {
